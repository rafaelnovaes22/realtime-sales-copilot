{
  "name": "realtime-sales-copilot",
  "version": "0.1.0",
  "private": true,
  "description": "Co-pilot de IA para closers de vendas consultivas em tempo real",
  "scripts": {
    "ingest": "tsx scripts/ingest.ts",
    "sanitize": "tsx scripts/sanitize.ts",
    "tag": "tsx --env-file=.env scripts/tag-corpus.ts",
    "corpus": "npm run ingest && npm run sanitize && npm run tag",
    "validate:corpus": "tsx scripts/validate-corpus-coverage.ts",
    "learning:report": "tsx --env-file=.env scripts/learning-report.ts",
    "test:deepgram": "tsx --env-file=.env scripts/test-deepgram.ts",
    "test:pipeline": "tsx --env-file=.env scripts/test-pipeline.ts",
    "dev:poc": "tsx --env-file=.env apps/web-poc/server.ts",
    "start:poc": "tsx apps/web-poc/server.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@deepgram/sdk": "^3.9.0",
    "@google/genai": "^2.10.0",
    "@hono/node-server": "^1.13.0",
    "@langchain/core": "^1.2.1",
    "@langchain/langgraph": "^1.4.7",
    "@types/pg": "^8.20.0",
    "hono": "^4.6.0",
    "iconv-lite": "^0.6.3",
    "langsmith": "^0.2.0",
    "pg": "^8.21.0",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.0",
    "unist-util-visit": "^5.0.0"
  }
}

{
  "version": "3",
  "lastUpdated": "2026-07-22",
  "description": "Glossário de sanitização de marca (exemplo de referência). Aplica-se no sanitize.ts entre corpus.raw.json e corpus.clean.json. O guardian regex em runtime usa o campo auditCheck como última camada antes de exibir sugestão ao closer. Substitua as entradas fictícias (Acme*) pelos termos proprietários do seu corpus real.",
  "replacements": {
    "AcmeSeguros": "[Seguradora]",
    "Acme Advisor": "consultor comercial",
    "AcmeAdvisor": "consultor comercial",
    "Corretora Parceira Acme": "corretora",
    "Corretoras Parceiras Acme": "corretoras",
    "Acme Academy": "academia de treinamento",
    "Clube Acme Elite": "programa de reconhecimento",
    "Sprint Acme": "bloco de treinamento",
    "Venda Conjunta Acme": "trabalho conjunto",
    "Abertura Acme": "abertura de reunião",
    "Diagnóstico Profundo Acme": "investigação aprofundada",
    "Mapa de Fatos Acme": "investigação de fatos"
  },
  "wordBoundaryReplacements": {
    "IND1": "indicação",
    "IND1s": "indicações",
    "FQ1": "ficha de prospecção",
    "CP1": "corretora",
    "CP1s": "corretoras"
  },
  "removePatterns": [
    "^\\*\\*Observa[çc][ãa]o:\\*\\*.*material.*propriet[áa]rio.*$",
    "^>?\\s*Material autoral.*$",
    "^>?\\s*Uso recomendado:.*$",
    ".*não deve ser apresentado como material oficial.*"
  ],
  "auditCheck": [
    "acmeseguros",
    "acme advisor",
    "\\bIND1\\b",
    "\\bFQ1\\b",
    "\\bCP1\\b",
    "acme academy",
    "acme elite",
    "\\[seguradora\\]",
    "\\[empresa\\]",
    "\\[marca\\]",
    "hubspot",
    "rd station",
    "activecamp",
    "salesforce",
    "pipedrive"
  ]
}

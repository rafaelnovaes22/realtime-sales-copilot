{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm install*)",
      "Bash(npm run dev*)",
      "Bash(npm run build*)",
      "Bash(npm run lint*)",
      "Bash(npm run format*)",
      "Bash(npm run test*)",
      "Bash(npm run test:watch*)",
      "Bash(npm run test:coverage*)",
      "Bash(npm run db:generate*)",
      "Bash(npm run db:migrate*)",
      "Bash(npm run db:push*)",
      "Bash(npm run db:studio*)",
      "Bash(npm run seed:*)",
      "Bash(npm run demo:*)",
      "Bash(npx prisma*)",
      "Bash(npx tsc*)",
      "Bash(npx tsx*)",
      "Bash(npx vitest*)",
      "Bash(docker compose*)",
      "Bash(docker ps*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(curl http://localhost:*)",
      "Bash(redis-cli -p 6380*)",
      "WebSearch",
      "WebFetch",
      "Bash(git clone *)",
      "Read(//c/tmp/agent-skills/**)",
      "Bash(grep -E \"\\\\.\\(md|json|yaml|yml\\)$\")",
      "Bash(xargs ls *)",
      "Bash(grep -E \"skills/[^/]+$\")",
      "Edit(/.claude/skills/L0/**)",
      "Edit(/.claude/skills/L2/**)",
      "Bash(python3 -c ' *)",
      "Edit(/.claude/skills/L1/**)",
      "Bash(python3 -c \"import sys,json; d=json.load\\(sys.stdin\\); print\\('version:', d.get\\('_forge_version'\\)\\); print\\('hooks keys:', list\\(d.get\\('hooks',{}\\).keys\\(\\)\\)\\)\")",
      "Bash(cp \".claude/skills/L0/using-forge.md\" \"C:/Users/Rafael/Projetos/Aicfo/.claude/skills/L0/using-forge.md\")",
      "Bash(cp \".claude/skills/L2/doubt-driven-review.md\" \"C:/Users/Rafael/Projetos/Aicfo/.claude/skills/L2/doubt-driven-review.md\")",
      "Bash(cp \".claude/skills/L2/debugging-pipeline.md\" \"C:/Users/Rafael/Projetos/Aicfo/.claude/skills/L2/debugging-pipeline.md\")",
      "Bash(cp \".claude/skills/L2/prompt-simplification.md\" \"C:/Users/Rafael/Projetos/Aicfo/.claude/skills/L2/prompt-simplification.md\")",
      "Bash(cp \".claude/skills/L1/forge-release-discipline.md\" \"C:/Users/Rafael/Projetos/Aicfo/.claude/skills/L1/forge-release-discipline.md\")",
      "Bash(cp \".claude/skills/L0/using-forge.md\" \"C:/Users/Rafael/Projetos/SchoolPlatform/.claude/skills/L0/using-forge.md\")",
      "Bash(cp \".claude/skills/L2/doubt-driven-review.md\" \"C:/Users/Rafael/Projetos/SchoolPlatform/.claude/skills/L2/doubt-driven-review.md\")",
      "Bash(cp \".claude/skills/L2/debugging-pipeline.md\" \"C:/Users/Rafael/Projetos/SchoolPlatform/.claude/skills/L2/debugging-pipeline.md\")",
      "Bash(cp \".claude/skills/L2/prompt-simplification.md\" \"C:/Users/Rafael/Projetos/SchoolPlatform/.claude/skills/L2/prompt-simplification.md\")",
      "Bash(cp \".claude/skills/L1/forge-release-discipline.md\" \"C:/Users/Rafael/Projetos/SchoolPlatform/.claude/skills/L1/forge-release-discipline.md\")",
      "Read(//c/Users/Rafael/.claude/projects/c--Users-Rafael-Projetos-agent-governance-framework/memory/**)"
    ],
    "deny": [
      "Bash(rm -rf*)",
      "Bash(rm -fr*)",
      "Bash(rm --recursive --force*)",
      "Bash(npm publish*)",
      "Bash(prisma migrate reset --force*)",
      "Bash(npx prisma migrate reset --force*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(docker system prune*)",
      "Bash(docker volume rm*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/session-start/forge-context.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/pre-tool-use/persona-detect.sh",
            "timeout": 2000
          },
          {
            "type": "command",
            "command": "bash hooks/pre-tool-use/outcome-clause-guard.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash hooks/pre-tool-use/adr-approval-gate.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash hooks/pre-tool-use/secret-scan.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash hooks/pre-tool-use/any-type-guard.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/post-tool-use/langfuse-trace-check.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash hooks/post-tool-use/unit-economics-recalc.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash hooks/post-tool-use/manifest-sync.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash hooks/post-tool-use/friendly-errors.sh",
            "timeout": 3000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/stop/5-gates-summary.sh",
            "timeout": 30000
          },
          {
            "type": "command",
            "command": "bash hooks/stop/eval-suite-fresh.sh",
            "timeout": 10000
          }
        ]
      }
    ]
  },
  "_comment": "Acme Forge layer (versioned). Per-developer overrides go in settings.local.json (gitignored).",
  "_forge_version": "0.21.0",
  "_constitution_version": "0.3.0",
  "_forge_features": {
    "skills_path": ".claude/skills/{L0,L1,L2}/",
    "agents_path": ".claude/agents/",
    "commands_path": ".claude/commands/acme/",
    "hooks_path": "hooks/",
    "bypass_env_var": "ACME_FORGE_BYPASS",
    "bypass_log_path": "docs/forge/bypass-log/",
    "bypass_note": "Set ACME_FORGE_BYPASS=<reason> in settings.local.json or env. All bypasses are logged."
  }
}

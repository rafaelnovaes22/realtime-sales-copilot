# templates/hermes/railway/env.example
#
# Variáveis de ambiente a configurar no Railway dashboard do serviço Hermes.
# Copie este arquivo e configure no painel Railway → Settings → Variables.
#
# Railway: https://railway.com/project/52bafdc5-3a22-4a45-a0ce-a5db94946866
# Docs:    https://docs.railway.app/guides/variables
#
# NUNCA commite valores reais aqui — apenas exemplos/placeholders.

# ─── OpenAI / Codex (já configurado no Hermes) ───────────────────────
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Telegram Gateway (já configurado no Hermes) ─────────────────────
TELEGRAM_BOT_TOKEN=1234567890:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# ─── GitHub — dispatch de workflows Forge ────────────────────────────
# PAT com scopes: repo (checkout privado) + workflow (disparar workflows)
# Criar em: https://github.com/settings/tokens/new
GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Org/repo canônico do Forge (não muda)
FORGE_REPO=acme-startup/agent-governance-framework

# ─── Hermes → Forge callback (webhook) ───────────────────────────────
# URL do endpoint /forge/callback exposto pelo Hermes Railway
# O próprio Hermes Railway já tem URL pública — substitua pelo seu domínio
HERMES_WEBHOOK_URL=https://hermes-production-xxxx.up.railway.app/forge/callback

# Secret HMAC para validar callbacks do GitHub Actions
# Gere com: openssl rand -hex 32
HERMES_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Segurança: chat_ids autorizados para comandos write ─────────────
# CSV de Telegram chat_ids que podem executar /acme:implement e /acme:promote
# Obtenha seu chat_id via @userinfobot no Telegram
# Exemplo: 123456789,987654321
HERMES_PRIVILEGED_CHAT_IDS=123456789

# ─── Paralelismo (opcional — Hermes respeita este limite) ─────────────
# Máximo de consumers simultâneos por dispatch (default: 3)
FORGE_MAX_PARALLEL_CONSUMERS=3

# ─── Polling interval quando webhook não está configurado ─────────────
# Segundos entre checks de status do GH run (default: 30)
FORGE_POLLING_INTERVAL_SECONDS=30

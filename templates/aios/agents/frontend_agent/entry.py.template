"""
Frontend Agent — implementa UI + telas de UM módulo.

Gerado a partir de templates/aios/agents/frontend_agent/entry.py.template (Forge v0.6.0+).
Stack lida de aios/config.yaml → stack.frontend (sem hardcode de framework).

C5/C6/C7/C8 — ver cabeçalho do spec_agent.

Substituições aplicadas pelo /acme:aios-init:
  {PROJECT_NAME}, {MODULE}, {TIER}
"""

import os
from pathlib import Path

import yaml
from cerebrum import BaseAgent

try:
    from langfuse import Langfuse
    _LF_AVAILABLE = bool(os.environ.get("LANGFUSE_PUBLIC_KEY"))
    if _LF_AVAILABLE:
        langfuse = Langfuse(
            public_key=os.environ["LANGFUSE_PUBLIC_KEY"],
            secret_key=os.environ.get("LANGFUSE_SECRET_KEY", ""),
            host=os.environ.get("LANGFUSE_HOST", "https://cloud.langfuse.com"),
        )
    else:
        langfuse = None
except Exception:
    _LF_AVAILABLE = False
    langfuse = None


class _MockTrace:
    id = "local-dev-no-trace"
    def generation(self, **_): return self
    def end(self, **_): pass
    def update(self, **_): pass


PROJECT_ROOT = Path(__file__).resolve().parents[3]
CONFIG_PATH = PROJECT_ROOT / "aios" / "config.yaml"


def _load_project_config() -> dict:
    if CONFIG_PATH.exists():
        with CONFIG_PATH.open("r", encoding="utf-8") as fh:
            return yaml.safe_load(fh) or {}
    return {}


_CONFIG = _load_project_config()
_PROJECT_NAME = _CONFIG.get("project", {}).get("name", "{PROJECT_NAME}")
_STACK_FRONTEND = _CONFIG.get("stack", {}).get("frontend", "(stack.frontend não declarado em aios/config.yaml — preencher antes de rodar)")


SYSTEM_PROMPT = f"""Você é o Frontend Agent do projeto {_PROJECT_NAME}.

Responsabilidade única: implementar componentes de UI e telas de UM módulo.

Stack obrigatória (declarada em aios/config.yaml → stack.frontend):
{_STACK_FRONTEND}

LEIA APENAS:
- A seção "Fluxos de tela" da spec do módulo (docs/specs/{{module}}.md)
- aios/config.yaml (apenas project.* e stack.*)
- O bloco "task" enviado pelo orquestrador

NÃO LEIA (isolamento de contexto C5):
- Specs de outros módulos
- Lógica de backend (use a API do módulo, não acesso direto a banco)
- Componentes específicos de outros módulos (apenas shared/ se a stack permitir)

Regras gerais:
- Componentização: separar list view, detail view, formulário e diálogos
- Estado mínimo no cliente — preferir server components/SSR quando a stack permitir
- Acessibilidade básica (labels, foco, contraste suficiente)
- Sem lógica de negócio no frontend (deixar no backend)
- Sem hardcode de tenant/cliente/unidade — usar contexto vindo do backend ou param de URL

Estrutura de output (adaptada à stack):
- Página de listagem
- Página/visão de detalhe + edição
- Componentes locais do módulo: Tabela, Formulário, Diálogos

C7: este prompt funciona standalone em Claude Code sem o kernel AIOS.
C8: tenantId vem do contexto/sessão, nunca hardcoded.
"""


class FrontendAgent(BaseAgent):
    agent_name = "{MODULE}_frontend_agent"

    def __init__(self, agent_name: str | None = None):
        super().__init__(agent_name or self.agent_name)
        self.messages = [{"role": "system", "content": SYSTEM_PROMPT}]

    def _load_context(self, module_name: str) -> dict:
        spec_path = PROJECT_ROOT / "docs" / "specs" / f"{module_name}.md"
        return {
            "spec": spec_path.read_text(encoding="utf-8") if spec_path.exists() else None,
        }

    def run(self, task_input: dict) -> dict:
        module_name = task_input.get("module")
        if not module_name:
            return {"error": "campo 'module' é obrigatório"}

        ctx = self._load_context(module_name)
        if not ctx["spec"]:
            return {"error": f"spec não encontrada: docs/specs/{module_name}.md"}

        trace = langfuse.trace(
            name=f"{self.agent_name}-{module_name}",
            metadata={
                "agent": self.agent_name,
                "project": _PROJECT_NAME,
                "module": module_name,
                "tier": task_input.get("tier", "{TIER}"),
                "tenant_id": task_input.get("tenant_id"),
                "stack": _STACK_FRONTEND,
                "aios_version": "0.2.2",
            },
        ) if _LF_AVAILABLE else _MockTrace()

        self.messages.append({
            "role": "user",
            "content": (
                f"Implemente o frontend do módulo: **{module_name}**\n\n"
                f"Spec do módulo (foque na seção Fluxos de Tela):\n{ctx['spec']}\n\n"
                f"Use a stack declarada em aios/config.yaml: {_STACK_FRONTEND}.\n"
                f"Os endpoints da API seguem o padrão consistente do projeto (ver _backend_{module_name}.md se já gerado)."
            ),
        })

        generation = trace.generation(
            name="send_request",
            model="claude-sonnet-4-6",
            input=self.messages,
        )

        response = self.send_request(
            agent_name=self.agent_name,
            messages=self.messages,
            base_url=f"http://localhost:{_CONFIG.get('server', {}).get('port', 8000)}",
            model=_CONFIG.get("llm", {}).get("model", "claude-sonnet-4-6"),
        )

        generation.end(output=response)
        trace.update(status_message="completed")

        output_path = PROJECT_ROOT / "docs" / "specs" / f"_frontend_{module_name}.md"
        output_path.write_text(response, encoding="utf-8")

        return {
            "module": module_name,
            "output_path": str(output_path),
            "trace_id": trace.id,
            "status": "frontend_generated",
            "note": "Revise e mova para src/ após aprovação humana (C4).",
        }

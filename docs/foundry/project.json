{
  "$schema": "https://novais-digital.com.br/foundry/project-config-v1.json",

  "project_config_version": "0.1.0",
  "framework_version_required": ">=0.21.0",
  "constitution_version_required": ">=0.3.0",

  "project": {
    "name": "realtime-sales-copilot",
    "owner": "Novais Digital",
    "type": "agentic_saas",
    "ai_enabled": true
  },

  "lifecycle_states": {
    "agentic": ["SHADOW", "ASSISTED", "AUTONOMOUS"],
    "platform": ["DRAFT", "STAGING", "PILOT", "CANONICAL", "DEPRECATED"],
    "default_for_project_type": {
      "agentic_saas": "agentic"
    }
  },

  "telemetry": {
    "llm_trace_provider": "langfuse",
    "audit_log_provider": null,
    "structured_logging_provider": "pino",
    "metrics_provider": null,
    "error_tracking_provider": null
  },

  "economics": {
    "model": "cost_per_outcome",
    "cost_to_price_ratio_max": 0.25,
    "platform_margin_inputs": {
      "infra_monthly_brl": null,
      "support_monthly_brl": null,
      "maintenance_monthly_brl": null,
      "revenue_monthly_brl": null
    }
  },

  "principle_overrides": {
    "C1": {
      "trigger_artifact": "diagnostic.md",
      "applies_to": "every agent before build"
    },
    "C2": {
      "outcome_clause_required": true,
      "outcome_kind_for_platform": null
    },
    "C3": {
      "model": "cost_per_outcome",
      "ratio_max": 0.25
    },
    "C4": {
      "agentic_modes": ["SHADOW", "ASSISTED", "AUTONOMOUS"],
      "platform_states": [],
      "min_window_days_critical_modules": 14,
      "min_window_days_simple_modules": 3
    },
    "C5": {
      "tier_vocabulary": "L0/L1/L2",
      "L0": "strategic (org-wide invariants)",
      "L1": "tactical (per product/customer)",
      "L2": "operational (per execution/run)"
    },
    "C6": {
      "telemetry_default_when_ai": "llm_trace_provider",
      "telemetry_default_when_no_ai": "audit_log_provider + structured_logging_provider",
      "trace_coverage_target_pct": 99
    },
    "C7": {
      "abstraction_layers_required_for": ["llm", "stt", "infra"]
    },
    "C8": {
      "tenant_customization_via": "config + tenant settings",
      "forbidden_patterns": ["if (tenantId === '...')", "switch (tenantName)"]
    }
  },
  "principle_overrides_signature": null,

  "modules": [
    {
      "id": "live-suggestion-copilot",
      "type": "agentic-skill",
      "ai_enabled": true,
      "lifecycle_state": "DRAFT",
      "criticality": "critical",
      "linked_diagnostic": "docs/clients/novais-digital-internal/diagnostic-live-suggestion-copilot.md",
      "linked_spec": "docs/specs/live-suggestion-copilot.md",
      "linked_economics": "docs/clients/novais-digital-internal/delivery-economics-live-suggestion-copilot.md"
    }
  ],

  "_meta": {
    "created_at": "2026-05-19",
    "last_updated": "2026-05-19",
    "validated_by_foundry_doctor": false,
    "consumer_repo": "https://github.com/novais-digital/realtime-sales-copilot",
    "notes": "Projeto agentic_saas focado em co-pilot de sugestões ao vivo para closers consultivos. Constitution-extension específica em examples/novais-digital-comercial/constitution-extension.md (brand sanitization + LGPD obrigatório + cards 1-2 linhas)."
  }
}

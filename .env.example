# Anthropic — Sonnet 4.6 (gerador) + Haiku 4.5 (detectores/guardian)
ANTHROPIC_API_KEY=sk-ant-...

# Deepgram — STT browser SDK PT-BR streaming
# Conta gratuita em https://deepgram.com (US$ 200 de crédito)
DEEPGRAM_API_KEY=...

# Observabilidade — LangSmith (opcional no MVP, obrigatório antes de SHADOW)
# Cria conta em https://smith.langchain.com e gera API key em Settings.
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=realtime-sales-copilot
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

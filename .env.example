# Gemini 2.5 Flash via Vertex AI — provider PRIMÁRIO (D011)
# Auth via ADC: dev local `gcloud auth application-default login`;
# Railway/não-GCP → GOOGLE_APPLICATION_CREDENTIALS apontando p/ SA key JSON.
GCP_PROJECT=
GCP_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=

# Anthropic — Sonnet 4.6 / Haiku 4.5 — provider FALLBACK (C7)
ANTHROPIC_API_KEY=sk-ant-...

# Pipeline: "true" usa o grafo de agentes LangGraph (objeções); ausente/false usa o linear (rollback)
USE_GRAPH_PIPELINE=true

# Deepgram — STT browser SDK PT-BR streaming
# Conta gratuita em https://deepgram.com (US$ 200 de crédito)
DEEPGRAM_API_KEY=...

# Observabilidade — LangSmith (opcional no MVP, obrigatório antes de SHADOW)
# Cria conta em https://smith.langchain.com e gera API key em Settings.
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=realtime-sales-copilot
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
